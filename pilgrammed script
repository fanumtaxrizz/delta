-- Логика стрельбы
local renderConnection = nil

local function startShooting()
    if renderConnection then return end
    renderConnection = RunService.RenderStepped:Connect(function()
        if isShooting then
            shootArrow()
        end
    end)
    statusText.Text = "Статус: АКТИВЕН 🔫"
    statusText.TextColor3 = Color3.fromRGB(100, 255, 100)
    toggleButton.Text = "⏸ СТОП"
    toggleButton.BackgroundColor3 = Color3.fromRGB(200, 80, 80)
    statusIcon.Text = "🔫"
end

local function stopShooting()
    if renderConnection then
        renderConnection:Disconnect()
        renderConnection = nil
    end
    statusText.Text = "Статус: ОСТАНОВЛЕН"
    statusText.TextColor3 = Color3.fromRGB(255, 100, 100)
    toggleButton.Text = "▶ СТАРТ"
    toggleButton.BackgroundColor3 = Color3.fromRGB(80, 180, 80)
    statusIcon.Text = "⚡"
end

-- Обработчики GUI
toggleButton.MouseButton1Click:Connect(function()
    if isShooting then
        isShooting = false
        stopShooting()
    else
        isShooting = true
        startShooting()
    end
end)

-- Изменение клавиши
local waitingForKey = false
changeKeyButton.MouseButton1Click:Connect(function()
    waitingForKey = true
    keybindText.Text = "..."
    keybindText.BackgroundColor3 = Color3.fromRGB(120, 100, 80)
    changeKeyButton.Text = "Ожидание..."
end)

UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    
    if waitingForKey then
        if input.KeyCode ~= Enum.KeyCode.Unknown then
            toggleKey = input.KeyCode
            keybindText.Text = tostring(toggleKey):gsub("Enum.KeyCode.", "")
            keybindText.BackgroundColor3 = Color3.fromRGB(55, 65, 90)
            changeKeyButton.Text = "Изменить"
            waitingForKey = false
            print("Клавиша изменена на: " .. tostring(toggleKey))
        end
        return
    end
    
    if input.KeyCode == toggleKey then
        if isShooting then
            isShooting = false
            stopShooting()
        else
            isShooting = true
            startShooting()
        end
    end
end)

-- Сворачивание
local minimized = false
local originalHeight = 450

minimizeButton.MouseButton1Click:Connect(function()
    minimized = not minimized
    if minimized then
        TweenService:Create(mainFrame, TweenInfo.new(0.3, Enum.EasingStyle.Quad), {Size = UDim2.new(0, 320, 0, 45)}):Play()
        contentFrame.Visible = false
        minimizeButton.Text = "□"
    else
        TweenService:Create(mainFrame, TweenInfo.new(0.3, Enum.EasingStyle.Quad), {Size = UDim2.new(0, 320, 0, originalHeight)}):Play()
        contentFrame.Visible = true
        minimizeButton.Text = "─"
    end
end)

