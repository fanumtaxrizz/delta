-- Ждём лук
local bow = character:WaitForChild("Prism Bow")
local shoot = bow:WaitForChild("Shoot")

-- Функция выстрела
local function shootArrow()
    if not player.Character or not player.Character:FindFirstChild("Prism Bow") then 
        isShooting = false
        return 
    end
    
    local humanoidRootPart = character:WaitForChild("HumanoidRootPart")
    local targetPosition = humanoidRootPart.Position + humanoidRootPart.CFrame.LookVector * distance
    
    local args = {
        targetPosition,
        currentArrow,
        true,
        1
    }
    
    pcall(function()
        shoot:InvokeServer(unpack(args))
    end)
end

