local waitingForKey = false
changeKeyButton.MouseButton1Click:Connect(function()
    waitingForKey = true
    keybindText.Text = "..."
    keybindText.BackgroundColor3 = Color3.fromRGB(120, 100, 80)
    changeKeyButton.Text = "Ожидание..."
end)

UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    
    if waitingForKey then
        if input.KeyCode ~= Enum.KeyCode.Unknown then
            toggleKey = input.KeyCode
            keybindText.Text = tostring(toggleKey):gsub("Enum.KeyCode.", "")
            keybindText.BackgroundColor3 = Color3.fromRGB(55, 65, 90)
            changeKeyButton.Text = "Изменить"
            waitingForKey = false
            print("Клавиша изменена на: " .. tostring(toggleKey))
        end
        return
    end
    
    if input.KeyCode == toggleKey then
        if isShooting then
            isShooting = false
            stopShooting()
        else
            isShooting = true
            startShooting()
        end
    end
end)

