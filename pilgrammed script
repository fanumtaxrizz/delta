-- Обновление статуса лука
local function updateBowStatus()
    local s = getShootFunction()
    if s then
        shoot = s
        bowStatus.Text = "🎯 Лук: НАЙДЕН ✅"
        bowStatus.TextColor3 = Color3.fromRGB(100, 255, 100)
        return true
    else
        shoot = nil
        bowStatus.Text = "🎯 Лук: НЕ НАЙДЕН (возьмите лук)"
        bowStatus.TextColor3 = Color3.fromRGB(255, 100, 100)
        return false
    end
end

-- Проверяем лук каждую секунду
task.spawn(function()
    while screenGui and screenGui.Parent do
        updateBowStatus()
        task.wait(1)
    end
end)

-- Логика стрельбы
local renderConnection = nil

local function startShooting()
    if renderConnection then return end
    renderConnection = RunService.RenderStepped:Connect(function()
        if isShooting then
            shootArrow()
        end
    end)
    statusText.Text = "🔫 Статус: АКТИВЕН"
    statusText.TextColor3 = Color3.fromRGB(100, 255, 100)
    toggleBtn.Text = "⏸ СТОП"
    toggleBtn.BackgroundColor3 = Color3.fromRGB(200, 80, 80)
end

local function stopShooting()
    if renderConnection then
        renderConnection:Disconnect()
        renderConnection = nil
    end
    statusText.Text = "⚡ Статус: ОСТАНОВЛЕН"
    statusText.TextColor3 = Color3.fromRGB(255, 100, 100)
    toggleBtn.Text = "▶ СТАРТ"
    toggleBtn.BackgroundColor3 = Color3.fromRGB(80, 180, 80)
end

-- Обработчики
toggleBtn.MouseButton1Click:Connect(function()
    if isShooting then
        isShooting = false
        stopShooting()
    else
        isShooting = true
        startShooting()
    end
end)

applyBtn.MouseButton1Click:Connect(function()
    local newArrow = arrowInput.Text
    if newArrow ~= "" then
        currentArrow = newArrow
        currentDisplay.Text = "📌 Текущая: " .. currentArrow
        print("Стрела: " .. currentArrow)
        applyBtn.BackgroundColor3 = Color3.fromRGB(100, 200, 100)
        task.wait(0.2)
        applyBtn.BackgroundColor3 = Color3.fromRGB(80, 140, 200)
    end
end)

-- Бинд клавиши T
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == toggleKey then
        if isShooting then
            isShooting = false
            stopShooting()
        else
            isShooting = true
            startShooting()
        end
    end
end)

-- Закрытие
closeBtn.MouseButton1Click:Connect(function()
    if renderConnection then
        renderConnection:Disconnect()
    end
    screenGui:Destroy()
end)

-- Перетаскивание
local dragStart, frameStart, dragging = nil, nil, false
titleBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = input.Position
        frameStart = mainFrame.Position
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = false
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        mainFrame.Position = UDim2.new(frameStart.X.Scale, frameStart.X.Offset + delta.X, frameStart.Y.Scale, frameStart.Y.Offset + delta.Y)
    end
end)

