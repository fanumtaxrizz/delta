-- ===== ФУНКЦИЯ ПОИСКА ЛУКА =====
local function findBow()
    local currentCharacter = player.Character
    if not currentCharacter then
        bow = nil
        shoot = nil
        bowStatusText.Text = "🎯 Лук: ПЕРСОНАЖ ОТСУТСТВУЕТ"
        bowStatusText.TextColor3 = Color3.fromRGB(255, 100, 100)
        return false
    end
    
    local foundBow = currentCharacter:FindFirstChild("Prism Bow")
    if foundBow then
        bow = foundBow
        shoot = bow:FindFirstChild("Shoot")
        if shoot then
            bowStatusText.Text = "🎯 Лук: НАЙДЕН ✅"
            bowStatusText.TextColor3 = Color3.fromRGB(100, 255, 100)
            return true
        else
            bowStatusText.Text = "🎯 Лук: НЕТ КОМПОНЕНТА SHOOT"
            bowStatusText.TextColor3 = Color3.fromRGB(255, 200, 100)
        end
    else
        bowStatusText.Text = "🎯 Лук: НЕ НАЙДЕН"
        bowStatusText.TextColor3 = Color3.fromRGB(255, 100, 100)
    end
    
    bow = nil
    shoot = nil
    return false
end

-- Функция выстрела (с проверкой наличия лука)
local function shootArrow()
    if not isShooting then return end
    
    -- Проверяем лук каждый раз
    if not bow or not shoot then
        if not findBow() then
            return
        end
    end
    
    local currentCharacter = player.Character
    if not currentCharacter then return end
    
    local humanoidRootPart = currentCharacter:FindFirstChild("HumanoidRootPart")
    if not humanoidRootPart then return end
    
    local targetPosition = humanoidRootPart.Position + humanoidRootPart.CFrame.LookVector * distance
    
    local args = {
        targetPosition,
        currentArrow,
        true,
        1
    }
    
    pcall(function()
        shoot:InvokeServer(unpack(args))
    end)
end

-- Поиск лука при смене персонажа или предмета
player.CharacterAdded:Connect(function(newCharacter)
    character = newCharacter
    findBow()
end)

-- Также проверяем при добавлении предметов (если лук появился позже)
if player.Character then
    player.Character.ChildAdded:Connect(function(child)
        if child.Name == "Prism Bow" then
            findBow()
        end
    end)
end

-- Начальный поиск лука
findBow()

-- ===== ЛОГИКА СТРЕЛЬБЫ =====
local renderConnection = nil

local function startShooting()
    if renderConnection then return end
    renderConnection = RunService.RenderStepped:Connect(function()
        if isShooting then
            shootArrow()
        end
    end)
    statusText.Text = "Статус: АКТИВЕН 🔫"
    statusText.TextColor3 = Color3.fromRGB(100, 255, 100)
    toggleButton.Text = "⏸ СТОП"
    toggleButton.BackgroundColor3 = Color3.fromRGB(200, 80, 80)
    statusIcon.Text = "🔫"
end

local function stopShooting()
    if renderConnection then
        renderConnection:Disconnect()
        renderConnection = nil
    end
    statusText.Text = "Статус: ОСТАНОВЛЕН"
    statusText.TextColor3 = Color3.fromRGB(255, 100, 100)
    toggleButton.Text = "▶ СТАРТ"
    toggleButton.BackgroundColor3 = Color3.fromRGB(80, 180, 80)
    statusIcon.Text = "⚡"
end

-- Обработчики GUI
toggleButton.MouseButton1Click:Connect(function()
    if isShooting then
        isShooting = false
        stopShooting()
    else
        isShooting = true
        startShooting()
    end
end)

