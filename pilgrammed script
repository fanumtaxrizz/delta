-- Логика ползунка
local draggingSlider = false

local function updateSliderPosition()
    local percent = (distance - minRange) / (maxRange - minRange)
    percent = math.clamp(percent, 0, 1)
    sliderFill.Size = UDim2.new(percent, 0, 1, 0)
    sliderButton.Position = UDim2.new(percent, -10, 0.5, -10)
    rangeLabel.Text = "📏 Дальность стрельбы: " .. math.floor(distance)
end

sliderButton.MouseButton1Down:Connect(function()
    draggingSlider = true
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        draggingSlider = false
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if draggingSlider and input.UserInputType == Enum.UserInputType.MouseMovement then
        local sliderPos = rangeSlider.AbsolutePosition.X
        local sliderWidth = rangeSlider.AbsoluteSize.X
        local mouseX = input.Position.X
        local percent = (mouseX - sliderPos) / sliderWidth
        percent = math.clamp(percent, 0, 1)
        distance = minRange + (maxRange - minRange) * percent
        updateSliderPosition()
    end
end)

-- Обновление статуса лука
local function updateBowStatus()
    local s = getShootFunction()
    if s then
        shoot = s
        bowStatusText.Text = "🎯 Лук: НАЙДЕН ✅"
        bowStatusText.TextColor3 = Color3.fromRGB(100, 255, 100)
        return true
    else
        shoot = nil
        bowStatusText.Text = "🎯 Лук: НЕ НАЙДЕН (возьмите лук)"
        bowStatusText.TextColor3 = Color3.fromRGB(255, 100, 100)
        return false
    end
end

-- Проверка лука
task.spawn(function()
    while screenGui and screenGui.Parent do
        updateBowStatus()
        task.wait(1)
    end
end)

-- Логика стрельбы
local renderConnection = nil

local function startShooting()
    if renderConnection then return end
    renderConnection = RunService.RenderStepped:Connect(function()
        if isShooting then
            shootArrow()
        end
    end)
    statusText.Text = "Статус: АКТИВЕН 🔫"
    statusText.TextColor3 = Color3.fromRGB(100, 255, 100)
    toggleButton.Text = "⏸ СТОП"
    toggleButton.BackgroundColor3 = Color3.fromRGB(200, 80, 80)
    statusIcon.Text = "🔫"
end

local function stopShooting()
    if renderConnection then
        renderConnection:Disconnect()
        renderConnection = nil
    end
    statusText.Text = "Статус: ОСТАНОВЛЕН"
    statusText.TextColor3 = Color3.fromRGB(255, 100, 100)
    toggleButton.Text = "▶ СТАРТ"
    toggleButton.BackgroundColor3 = Color3.fromRGB(80, 180, 80)
    statusIcon.Text = "⚡"
end

-- Обработчики GUI
