-- ===== НАСТРОЙКИ =====
local distance = 500  -- начальная дальность
local isShooting = false
local currentArrow = "Arrow"
local toggleKey = Enum.KeyCode.T
local shootDelay = 0.1  -- задержка между выстрелами

-- Переменные для лука
local shoot = nil
local lastShootTime = 0

-- Функция получения лука
local function getShootFunction()
    local character = player.Character
    if not character then return nil end
    local bow = character:FindFirstChild("Prism Bow")
    if not bow then return nil end
    return bow:FindFirstChild("Shoot")
end

-- Функция выстрела с задержкой
local function shootArrow()
    if not isShooting then return end
    
    local now = tick()
    if now - lastShootTime < shootDelay then
        return
    end
    lastShootTime = now
    
    if not shoot then
        shoot = getShootFunction()
        if not shoot then return end
    end
    
    local character = player.Character
    if not character then return end
    
    local humanoidRootPart = character:FindFirstChild("HumanoidRootPart")
    if not humanoidRootPart then return end
    
    local targetPosition = humanoidRootPart.Position + humanoidRootPart.CFrame.LookVector * distance
    
    pcall(function()
        shoot:InvokeServer(targetPosition, currentArrow, true, 1)
    end)
end

