local function setupKeybinds()
    UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed then return end
        
        -- Телепорт
        if input.KeyCode == Enum.KeyCode[teleportKeybind] then
            teleportUp()
        end
        
        -- Скрытие меню
        if input.KeyCode == Enum.KeyCode[hideKeybind] then
            isMenuVisible = not isMenuVisible
            screenGui.Enabled = isMenuVisible
        end
        
        -- Переключение аимбота
        if input.KeyCode == Enum.KeyCode[aimbotKeybind] then
            toggleAimbot()
        end
    end)
end

