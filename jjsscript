-- Функции
local function formatNumber(num)
    if num >= 1000000 then return string.format("%.1fM", num / 1000000)
    elseif num >= 1000 then return string.format("%.1fK", num / 1000)
    else return tostring(num) end
end

-- ===== ГРАВИТАЦИЯ =====
local function updateGravity()
    if gravityEnabled then
        workspace.Gravity = originalGravity * gravityMultiplier
    else
        workspace.Gravity = originalGravity
    end
end

local function toggleGravity()
    gravityEnabled = not gravityEnabled
    updateGravity()
    if gravityEnabled then
        gravityStatus.Text = "🌍 ГРАВИТАЦИЯ: " .. string.format("%.1f", gravityMultiplier) .. "x"
        gravityToggle.Text = "🌍 ВЫКЛ"
        gravityToggle.BackgroundColor3 = Color3.fromRGB(200, 60, 60)
        statusLabel.Text = "🌍 Гравитация изменена на x" .. string.format("%.1f", gravityMultiplier)
    else
        gravityStatus.Text = "🌍 ГРАВИТАЦИЯ: ВЫКЛ"
        gravityToggle.Text = "🌍 ВКЛ"
        gravityToggle.BackgroundColor3 = Color3.fromRGB(0, 150, 0)
        statusLabel.Text = "🌍 Гравитация恢复正常"
    end
    task.wait(1.5)
    if isAlive then statusLabel.Text = "✅ Жив" end
end

-- ===== АИМБОТ =====
local function getClosestPlayer()
    if not currentCharacter or not currentCharacter:FindFirstChild("HumanoidRootPart") then return nil end
    local myPos = currentCharacter.HumanoidRootPart.Position
    local closest, closestDist = nil, math.huge
    for _, other in ipairs(Players:GetPlayers()) do
        if other ~= player then
            local char = other.Character
            if char and char:FindFirstChild("HumanoidRootPart") and char:FindFirstChild("Humanoid") and char.Humanoid.Health > 0 then
                local dist = (myPos - char.HumanoidRootPart.Position).Magnitude
                if dist < closestDist and dist < 500 then
                    closest, closestDist = other, dist
                end
            end
        end
    end
    return closest
end

local aimbotConnection = nil
local function startAimbot()
    if aimbotConnection then aimbotConnection:Disconnect() end
    aimbotConnection = RunService.RenderStepped:Connect(function()
        if aimbotEnabled and isAlive and currentCharacter then
            local target = getClosestPlayer()
            if target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
                local targetPos = target.Character.HumanoidRootPart.Position + Vector3.new(0, 1.5, 0)
                if sprayEnabled then
                    targetPos = targetPos + Vector3.new((math.random() - 0.5) * sprayAmount * 10, (math.random() - 0.5) * sprayAmount * 8, (math.random() - 0.5) * sprayAmount * 10)
                end
                local newCF = camera.CFrame:Lerp(CFrame.new(camera.CFrame.Position, targetPos), aimbotSmoothness)
                camera.CFrame = newCF
            end
        end
    end)
end

local function toggleAimbot()
    aimbotEnabled = not aimbotEnabled
    if aimbotEnabled then
        startAimbot()
        statusLabel.Text = "🎯 Аимбот ВКЛ"
        aimbotStatus.Text = "🔴 АИМБОТ ВКЛ"
        aimbotStatus.TextColor3 = Color3.fromRGB(255, 100, 100)
        aimbotToggle.Text = "🔴 ВЫКЛ"
        aimbotToggle.BackgroundColor3 = Color3.fromRGB(200, 60, 60)
    else
        if aimbotConnection then aimbotConnection:Disconnect() end
        statusLabel.Text = "❌ Аимбот ВЫКЛ"
        aimbotStatus.Text = "⚪ АИМБОТ ВЫКЛ"
        aimbotStatus.TextColor3 = Color3.fromRGB(200, 200, 200)
        aimbotToggle.Text = "🟢 ВКЛ"
        aimbotToggle.BackgroundColor3 = Color3.fromRGB(100, 100, 100)
    end
    task.wait(1.5)
    if isAlive then statusLabel.Text = "✅ Жив" end
end

-- ===== VELOCITY =====
local function activateVelocity()
    if not isAlive then statusLabel.Text = "❌ Вы мертвы!" return end
    local hrp = currentCharacter and currentCharacter:FindFirstChild("HumanoidRootPart")
    local hum = currentCharacter and currentCharacter:FindFirstChild("Humanoid")
    if hrp and hum and hum.Health > 0 then
        local oldGrav = workspace.Gravity
        workspace.Gravity = 0
        local vel = math.sqrt(2 * teleportHeight * 50) * velocityMultiplier
        hrp.Velocity = Vector3.new(0, vel, 0)
        hrp.AssemblyLinearVelocity = Vector3.new(0, vel, 0)
        task.wait(0.05)
        workspace.Gravity = oldGrav
        teleportCount = teleportCount + 1
        counterLabel.Text = "📊 " .. teleportCount .. " | x" .. string.format("%.1f", velocityMultiplier)
        statusLabel.Text = "✅ Телепорт!"
        local att = Instance.new("Attachment")
        att.Parent = hrp
        local smoke = Instance.new("Smoke")
        smoke.Parent = att
        game:GetService("Debris"):AddItem(smoke, 2)
        game:GetService("Debris"):AddItem(att, 2)
        task.wait(1.5)
        if isAlive then statusLabel.Text = "✅ Жив" end
    else
        statusLabel.Text = "❌ Ошибка!"
    end
end

