local function updateSliderValue(value)
    local minVal = 1
    local maxVal = 1000000
    local percent = (value - minVal) / (maxVal - minVal)
    percent = math.clamp(percent, 0, 1)
    sliderFill.Size = UDim2.new(percent, 0, 1, 0)
    sliderButton.Position = UDim2.new(percent, -10, 0.5, -10)
end

local function getValueFromSliderPosition(inputPosition)
    local sliderAbsPos = sliderFrame.AbsolutePosition
    local sliderWidth = sliderFrame.AbsoluteSize.X
    local clickX = inputPosition.X - sliderAbsPos.X
    local percent = math.clamp(clickX / sliderWidth, 0, 1)
    local minVal = 1
    local maxVal = 1000000
    return math.floor(minVal + (maxVal - minVal) * percent)
