-- Функции для ползунков
local isDraggingHeight = false
local isDraggingVelocity = false
local isDraggingPlatformSpeed = false
local isDraggingPlatformHeight = false
local isDraggingSmoothness = false
local isDraggingSpray = false

heightSliderButton.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        isDraggingHeight = true
        local percent = (input.Position.X - heightSliderFrame.AbsolutePosition.X) / heightSliderFrame.AbsoluteSize.X
        percent = math.clamp(percent, 0, 1)
        teleportHeight = math.floor(percent * 1000000)
        updateHeightSlider(teleportHeight)
        heightInputBox.Text = tostring(teleportHeight)
    end
end)

velocitySliderButton.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        isDraggingVelocity = true
        local percent = (input.Position.X - velocitySliderFrame.AbsolutePosition.X) / velocitySliderFrame.AbsoluteSize.X
        percent = math.clamp(percent, 0, 1)
        velocityMultiplier = percent * 5
        updateVelocitySlider(velocityMultiplier)
        velocityInputBox.Text = string.format("%.1f", velocityMultiplier)
    end
end)

platformSpeedSliderButton.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        isDraggingPlatformSpeed = true
        local percent = (input.Position.X - platformSpeedSliderFrame.AbsolutePosition.X) / platformSpeedSliderFrame.AbsoluteSize.X
        percent = math.clamp(percent, 0, 1)
        local newSpeed = percent * 270 + 30
        platformSpeed = math.clamp(newSpeed, 30, 300)
        updatePlatformSpeedSlider(platformSpeed)
    end
end)

platformHeightSliderButton.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        isDraggingPlatformHeight = true
        local percent = (input.Position.X - platformHeightSliderFrame.AbsolutePosition.X) / platformHeightSliderFrame.AbsoluteSize.X
        percent = math.clamp(percent, 0, 1)
        local newHeight = percent * 990 + 10
        platformMaxHeight = math.floor(newHeight)
        updatePlatformHeightSlider(platformMaxHeight)
    end
end)

smoothnessSliderButton.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        isDraggingSmoothness = true
        local percent = (input.Position.X - smoothnessSliderFrame.AbsolutePosition.X) / smoothnessSliderFrame.AbsoluteSize.X
        percent = math.clamp(percent, 0, 1)
        local newSmoothness = percent * 0.45 + 0.05
        aimbotSmoothness = math.clamp(newSmoothness, 0.05, 0.5)
        updateSmoothnessSlider(aimbotSmoothness)
    end
end)

spraySliderButton.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        isDraggingSpray = true
        local percent = (input.Position.X - spraySliderFrame.AbsolutePosition.X) / spraySliderFrame.AbsoluteSize.X
        percent = math.clamp(percent, 0, 1)
        sprayAmount = percent * 0.3
        updateSpraySlider(sprayAmount)
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if isDraggingHeight and input.UserInputType == Enum.UserInputType.MouseMovement then
        local percent = (input.Position.X - heightSliderFrame.AbsolutePosition.X) / heightSliderFrame.AbsoluteSize.X
        percent = math.clamp(percent, 0, 1)
        teleportHeight = math.floor(percent * 1000000)
        updateHeightSlider(teleportHeight)
        heightInputBox.Text = tostring(teleportHeight)
    elseif isDraggingVelocity and input.UserInputType == Enum.UserInputType.MouseMovement then
        local percent = (input.Position.X - velocitySliderFrame.AbsolutePosition.X) / velocitySliderFrame.AbsoluteSize.X
        percent = math.clamp(percent, 0, 1)
        velocityMultiplier = percent * 5
        updateVelocitySlider(velocityMultiplier)
        velocityInputBox.Text = string.format("%.1f", velocityMultiplier)
    elseif isDraggingPlatformSpeed and input.UserInputType == Enum.UserInputType.MouseMovement then
        local percent = (input.Position.X - platformSpeedSliderFrame.AbsolutePosition.X) / platformSpeedSliderFrame.AbsoluteSize.X
        percent = math.clamp(percent, 0, 1)
        local newSpeed = percent * 270 + 30
        platformSpeed = math.clamp(newSpeed, 30, 300)
        updatePlatformSpeedSlider(platformSpeed)
    elseif isDraggingPlatformHeight and input.UserInputType == Enum.UserInputType.MouseMovement then
        local percent = (input.Position.X - platformHeightSliderFrame.AbsolutePosition.X) / platformHeightSliderFrame.AbsoluteSize.X
        percent = math.clamp(percent, 0, 1)
        local newHeight = percent * 990 + 10
        platformMaxHeight = math.floor(newHeight)
        updatePlatformHeightSlider(platformMaxHeight)
    elseif isDraggingSmoothness and input.UserInputType == Enum.UserInputType.MouseMovement then
        local percent = (input.Position.X - smoothnessSliderFrame.AbsolutePosition.X) / smoothnessSliderFrame.AbsoluteSize.X
        percent = math.clamp(percent, 0, 1)
        aimbotSmoothness = percent * 0.45 + 0.05
        updateSmoothnessSlider(aimbotSmoothness)
    elseif isDraggingSpray and input.UserInputType == Enum.UserInputType.MouseMovement then
        local percent = (input.Position.X - spraySliderFrame.AbsolutePosition.X) / spraySliderFrame.AbsoluteSize.X
        percent = math.clamp(percent, 0, 1)
        sprayAmount = percent * 0.3
        updateSpraySlider(sprayAmount)
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        isDraggingHeight = false
        isDraggingVelocity = false
        isDraggingPlatformSpeed = false
        isDraggingPlatformHeight = false
        isDraggingSmoothness = false
        isDraggingSpray = false
    end
end)

-- Применение значений
local function applyHeight()
    local num = tonumber(heightInputBox.Text)
    if num then
        teleportHeight = math.clamp(math.floor(num), 1, 1000000)
        updateHeightSlider(teleportHeight)
        heightInputBox.Text = tostring(teleportHeight)
    else
        heightInputBox.Text = tostring(teleportHeight)
    end
end

local function applyVelocity()
    local num = tonumber(velocityInputBox.Text)
    if num then
        velocityMultiplier = math.clamp(num, 0.1, 5)
        updateVelocitySlider(velocityMultiplier)
        velocityInputBox.Text = string.format("%.1f", velocityMultiplier)
    else
        velocityInputBox.Text = string.format("%.1f", velocityMultiplier)
    end
end

local function toggleSpray()
    sprayEnabled = not sprayEnabled
    if sprayEnabled then
        sprayToggleButton.BackgroundColor3 = Color3.fromRGB(0, 150, 0)
        sprayToggleButton.Text = "🔘 СПРЕЙ ВКЛ"
    else
        sprayToggleButton.BackgroundColor3 = Color3.fromRGB(150, 0, 0)
        sprayToggleButton.Text = "❌ СПРЕЙ ВЫКЛ"
    end
end

heightApplyButton.MouseButton1Click:Connect(applyHeight)
heightInputBox.FocusLost:Connect(function(enter) if enter then applyHeight() end end)
velocityApplyButton.MouseButton1Click:Connect(applyVelocity)
velocityInputBox.FocusLost:Connect(function(enter) if enter then applyVelocity() end end)
sprayToggleButton.MouseButton1Click:Connect(toggleSpray)

-- Горячие клавиши
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    
    if input.KeyCode == Enum.KeyCode[actionKeybind] then
        if selectedMethod == "Velocity" then
            activateVelocity()
        else
            platformAction()
        end
    end
    
    if input.KeyCode == Enum.KeyCode[hideKeybind] then
        isMenuVisible = not isMenuVisible
        screenGui.Enabled = isMenuVisible
    end
    
    if input.KeyCode == Enum.KeyCode[aimbotKeybind] then
        toggleAimbot()
    end
end)

-- Отслеживание персонажа
local function onCharacterAdded(newChar)
    currentCharacter = newChar
    isAlive = true
    statusLabel.Text = "✅ Персонаж жив"
    platformStatusLabel.Text = "✅ Персонаж жив"
    
    if platform then
        platform:Destroy()
        platform = nil
    end
    platformActive = false
    if platformTween then
        platformTween:Cancel()
        platformTween = nil
    end
    if platformRenderConnection then
        platformRenderConnection:Disconnect()
        platformRenderConnection = nil
    end
    
    local humanoid = newChar:WaitForChild("Humanoid")
    humanoid.Died:Connect(function()
        isAlive = false
        statusLabel.Text = "💀 Вы умерли!"
        platformStatusLabel.Text = "💀 Вы умерли!"
        if aimbotEnabled then
            toggleAimbot()
        end
    end)
end

if player.Character then
    onCharacterAdded(player.Character)
end
player.CharacterAdded:Connect(onCharacterAdded)

-- Перетаскивание окна
local dragging = false
local dragStart = nil
local frameStart = nil

titleBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = input.Position
        frameStart = mainFrame.Position
        titleBar.BackgroundColor3 = Color3.fromRGB(70, 70, 95)
    end
end)

titleBar.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        local newX = frameStart.X.Offset + delta.X
        local newY = frameStart.Y.Offset + delta.Y
        local screenSize = workspace.CurrentCamera.ViewportSize
        local frameSize = mainFrame.AbsoluteSize
        newX = math.clamp(newX, 0, screenSize.X - frameSize.X)
        newY = math.clamp(newY, 0, screenSize.Y - frameSize.Y)
        mainFrame.Position = UDim2.new(0, newX, 0, newY)
    end
end)

titleBar.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = false
        titleBar.BackgroundColor3 = Color3.fromRGB(50, 50, 70)
    end
end)

-- Сворачивание
local minimized = false
minimizeButton.MouseButton1Click:Connect(function()
    minimized = not minimized
    if minimized then
        contentFrame.Visible = false
        minimizeButton.Text = "□"
        mainFrame.Size = UDim2.new(0, 420, 0, 45)
    else
        contentFrame.Visible = true
        minimizeButton.Text = "−"
        mainFrame.Size = UDim2.new(0, 420, 0, 580)
    end
end)

closeButton.MouseButton1Click:Connect(function()
    if aimbotConnection then
        aimbotConnection:Disconnect()
    end
    if platform then
        platform:Destroy()
    end
    screenGui:Destroy()
end)

