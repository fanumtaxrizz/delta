-- Ползунок скорости Velocity
local function updateVelSlider(val)
    local p = (val - 0.1) / 4.9
    p = math.clamp(p, 0, 1)
    velFill.Size = UDim2.new(p, 0, 1, 0)
    velBtn.Position = UDim2.new(p, -10, 0.5, -10)
    velValue.Text = "x" .. string.format("%.1f", val)
    velocityMultiplier = val
end

velBtn.MouseButton1Down:Connect(function()
    local moving = true
    local con
    con = UserInputService.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement and moving then
            local mousePos = UserInputService:GetMouseLocation()
            local sliderPos = velSlider.AbsolutePosition.X
            local sliderW = velSlider.AbsoluteSize.X
            local p = (mousePos.X - sliderPos) / sliderW
            p = math.clamp(p, 0, 1)
            local newVal = 0.1 + p * 4.9
            updateVelSlider(newVal)
            velInput.Text = string.format("%.1f", newVal)
        end
    end)
    local rel
    rel = UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            moving = false
            con:Disconnect()
            rel:Disconnect()
        end
    end)
end)

velSlider.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        local mousePos = input.Position
        local sliderPos = velSlider.AbsolutePosition.X
        local sliderW = velSlider.AbsoluteSize.X
        local p = (mousePos.X - sliderPos) / sliderW
        p = math.clamp(p, 0, 1)
        local newVal = 0.1 + p * 4.9
        updateVelSlider(newVal)
        velInput.Text = string.format("%.1f", newVal)
    end
end)

