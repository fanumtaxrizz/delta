-- Функция для нахождения ближайшего игрока
local function getClosestPlayer()
    local closestPlayer = nil
    local closestDistance = math.huge
    
    if not currentCharacter or not currentCharacter:FindFirstChild("HumanoidRootPart") then
        return nil
    end
    
    local myPosition = currentCharacter.HumanoidRootPart.Position
    
    for _, otherPlayer in ipairs(Players:GetPlayers()) do
        if otherPlayer ~= player then
            local otherChar = otherPlayer.Character
            if otherChar and otherChar:FindFirstChild("HumanoidRootPart") and otherChar:FindFirstChild("Humanoid") and otherChar.Humanoid.Health > 0 then
                local otherPosition = otherChar.HumanoidRootPart.Position
                local distance = (myPosition - otherPosition).Magnitude
                
                if distance < closestDistance and distance < 500 then
                    closestDistance = distance
                    closestPlayer = otherPlayer
                end
            end
        end
    end
    
    return closestPlayer, closestDistance
end

-- Функция для применения спрея (разброса)
local function applySpray(targetPosition)
    if not sprayEnabled then
        return targetPosition
    end
    
    -- Случайное смещение в пределах sprayAmount (в студнях)
    local offsetX = (math.random() - 0.5) * sprayAmount * 10
    local offsetY = (math.random() - 0.5) * sprayAmount * 8
    local offsetZ = (math.random() - 0.5) * sprayAmount * 10
    
    return targetPosition + Vector3.new(offsetX, offsetY, offsetZ)
end

-- Функция аимбота (постоянное слежение)
local aimbotConnection = nil
local function startAimbot()
    if aimbotConnection then
        aimbotConnection:Disconnect()
        aimbotConnection = nil
    end
    
    aimbotConnection = RunService.RenderStepped:Connect(function()
        if aimbotEnabled and isAlive and currentCharacter then
            local targetPlayer, distance = getClosestPlayer()
            
            if targetPlayer then
                local targetChar = targetPlayer.Character
                if targetChar and targetChar:FindFirstChild("HumanoidRootPart") then
                    local targetPos = targetChar.HumanoidRootPart.Position + Vector3.new(0, 1.5, 0)
                    
                    -- Применяем спрей
                    local sprayedPos = applySpray(targetPos)
                    
                    -- Плавное наведение
                    local currentCFrame = camera.CFrame
                    local targetCFrame = CFrame.new(camera.CFrame.Position, sprayedPos)
                    
                    local newCFrame = currentCFrame:Lerp(targetCFrame, aimbotSmoothness)
                    camera.CFrame = newCFrame
                end
            end
        end
    end)
end

-- Функция переключения аимбота
local function toggleAimbot()
    aimbotEnabled = not aimbotEnabled
    
    if aimbotEnabled then
        aimbotStatusText.Text = "🔴 АИМБОТ ВКЛЮЧЕН"
        aimbotStatusText.TextColor3 = Color3.fromRGB(255, 100, 100)
        aimbotToggleButton.BackgroundColor3 = Color3.fromRGB(200, 60, 60)
        aimbotToggleButton.Text = "🔴 ВЫКЛЮЧИТЬ"
        startAimbot()
        statusLabel.Text = "🎯 Аимбот ВКЛЮЧЁН (следит за врагами)"
        statusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
    else
        aimbotStatusText.Text = "⚪ АИМБОТ ВЫКЛЮЧЕН"
        aimbotStatusText.TextColor3 = Color3.fromRGB(200, 200, 200)
        aimbotToggleButton.BackgroundColor3 = Color3.fromRGB(100, 100, 100)
        aimbotToggleButton.Text = "🟢 ВКЛЮЧИТЬ"
        if aimbotConnection then
            aimbotConnection:Disconnect()
            aimbotConnection = nil
        end
        statusLabel.Text = "❌ Аимбот ВЫКЛЮЧЁН"
        statusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
    end
    
    task.wait(1.5)
    if isAlive then
        statusLabel.Text = "✅ Персонаж жив"
        statusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
    end
end

-- Функции ползунков
local function updateSliderValue(value)
    local minVal = 1
    local maxVal = 1000000
    local percent = (value - minVal) / (maxVal - minVal)
    percent = math.clamp(percent, 0, 1)
    sliderFill.Size = UDim2.new(percent, 0, 1, 0)
    sliderButton.Position = UDim2.new(percent, -10, 0.5, -10)
end

local function getValueFromSliderPosition(inputPosition)
    local sliderAbsPos = sliderFrame.AbsolutePosition
    local sliderWidth = sliderFrame.AbsoluteSize.X
    local clickX = inputPosition.X - sliderAbsPos.X
    local percent = math.clamp(clickX / sliderWidth, 0, 1)
    local minVal = 1
    local maxVal = 1000000
    return math.floor(minVal + (maxVal - minVal) * percent)
end

local function updateVelocitySlider(value)
    local minVal = 0.1
