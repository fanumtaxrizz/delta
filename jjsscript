-- Функция телепортации
local function teleportUp()
    local currentCharacter = player.Character
    if currentCharacter then
        local humanoidRootPart = currentCharacter:FindFirstChild("HumanoidRootPart")
        if humanoidRootPart then
            local currentPosition = humanoidRootPart.Position
            local newPosition = Vector3.new(currentPosition.X, currentPosition.Y + teleportHeight, currentPosition.Z)
            humanoidRootPart.CFrame = CFrame.new(newPosition)
            
            teleportCount = teleportCount + 1
            counterLabel.Text = "Телепортов: " .. teleportCount .. " (всего поднялся на " .. formatNumber(teleportCount * teleportHeight) .. " студней)"
            
            -- Визуальный эффект
            local attachment = Instance.new("Attachment")
            attachment.Parent = humanoidRootPart
            local smoke = Instance.new("Smoke")
            smoke.Parent = attachment
            game:GetService("Debris"):AddItem(smoke, 2)
            game:GetService("Debris"):AddItem(attachment, 2)
            
            -- Анимация кнопки
            local clickTween = TweenService:Create(teleportButton, TweenInfo.new(0.1, Enum.EasingStyle.Quad), {
                BackgroundColor3 = Color3.fromRGB(0, 200, 100)
            })
            clickTween:Play()
            task.wait(0.1)
            local resetTween = TweenService:Create(teleportButton, TweenInfo.new(0.1, Enum.EasingStyle.Quad), {
                BackgroundColor3 = Color3.fromRGB(0, 120, 255)
            })
            resetTween:Play()
        end
    end
end

teleportButton.MouseButton1Click:Connect(teleportUp)

-- Перетаскивание окна
local function startDrag(input)
    dragging = true
    dragStart = input.Position
    startPos = mainFrame.Position
end

local function drag(input)
    if dragging then
        local delta = input.Position - dragStart
        local newX = startPos.X.Offset + delta.X
        local newY = startPos.Y.Offset + delta.Y
        
        newX = math.clamp(newX, 0, 1 - mainFrame.Size.X.Scale)
        newY = math.clamp(newY, 0, 1 - mainFrame.Size.Y.Scale)
        
        mainFrame.Position = UDim2.new(startPos.X.Scale, newX, startPos.Y.Scale, newY)
    end
end

local function stopDrag()
    dragging = false
end

