-- ===== ФУНКЦИИ VELOCITY =====
local function teleportViaVelocity()
    if not currentCharacter then return false end
    
    local hrp = currentCharacter:FindFirstChild("HumanoidRootPart")
    local humanoid = currentCharacter:FindFirstChild("Humanoid")
    
    if hrp and humanoid and humanoid.Health > 0 then
        local originalGravity = workspace.Gravity
        workspace.Gravity = 0
        
        local velocity = math.sqrt(2 * teleportHeight * 50) * velocityMultiplier
        hrp.Velocity = Vector3.new(0, velocity, 0)
        hrp.AssemblyLinearVelocity = Vector3.new(0, velocity, 0)
        
        task.wait(0.05)
        workspace.Gravity = originalGravity
        return true
    end
    return false
end

local function activateVelocity()
    if not isAlive then
        statusLabel.Text = "❌ Вы мертвы!"
        return
    end
    
    if teleportViaVelocity() then
        teleportCount = teleportCount + 1
        counterLabel.Text = "Активаций: " .. teleportCount .. " [Velocity x" .. string.format("%.1f", velocityMultiplier) .. "]"
        statusLabel.Text = "✅ Телепорт успешен!"
        
        if currentCharacter and currentCharacter:FindFirstChild("HumanoidRootPart") then
            local hrp = currentCharacter.HumanoidRootPart
            local attachment = Instance.new("Attachment")
            attachment.Parent = hrp
            local smoke = Instance.new("Smoke")
            smoke.Parent = attachment
            game:GetService("Debris"):AddItem(smoke, 2)
            game:GetService("Debris"):AddItem(attachment, 2)
        end
        
        task.wait(1.5)
        if isAlive then
            statusLabel.Text = "✅ Персонаж жив"
        end
    else
        statusLabel.Text = "❌ Ошибка!"
    end
end

-- ===== ФУНКЦИИ ПЛАТФОРМЫ =====
local function createPlatform()
    if not currentCharacter then return nil end
    
    local hrp = currentCharacter:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil end
    
    local platformPart = Instance.new("Part")
    platformPart.Name = "FastPlatform"
    platformPart.Size = Vector3.new(6, 0.5, 6)
    platformPart.Position = hrp.Position - Vector3.new(0, 2.5, 0)
    platformPart.Anchored = true
    platformPart.CanCollide = true
    platformPart.Transparency = 0.2
    platformPart.Color = platformColor
    platformPart.Material = Enum.Material.Neon
    platformPart.Parent = Workspace
    
    return platformPart
end

local function platformAction()
    if not isAlive then
        platformStatusLabel.Text = "❌ Вы мертвы!"
        return
    end
    
    if not currentCharacter then
        platformStatusLabel.Text = "⚠️ Персонаж не загружен..."
        return
    end
    
    if platformActive then
        if platform then
            platform:Destroy()
            platform = nil
        end
        if platformTween then
            platformTween:Cancel()
            platformTween = nil
        end
        if platformRenderConnection then
            platformRenderConnection:Disconnect()
            platformRenderConnection = nil
        end
        platformActive = false
        platformStatusLabel.Text = "🔼 Платформа удалена! Вы остались на месте"
        platformStatusLabel.TextColor3 = Color3.fromRGB(255, 200, 100)
        task.wait(1.5)
        if isAlive then
            platformStatusLabel.Text = "✅ Персонаж жив"
            platformStatusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
        end
    else
        platform = createPlatform()
        if platform then
            platformActive = true
            
            local hrp = currentCharacter:FindFirstChild("HumanoidRootPart")
            if hrp then
                local targetY = hrp.Position.Y + platformMaxHeight
                local duration = platformMaxHeight / platformSpeed
                
                platformTween = TweenService:Create(hrp, TweenInfo.new(duration, Enum.EasingStyle.Linear), {
                    CFrame = CFrame.new(hrp.Position.X, targetY, hrp.Position.Z)
                })
                
                platformRenderConnection = RunService.RenderStepped:Connect(function()
                    if platform and platform.Parent and hrp and hrp.Parent then
                        platform.Position = hrp.Position - Vector3.new(0, 2.5, 0)
                    end
                end)
                
                platformTween:Play()
                
                local currentCount = tonumber(platformCounterLabel.Text:match("%d+")) or 0
                platformCounterLabel.Text = "Активаций: " .. (currentCount + 1)
                
                platformTween.Completed:Connect(function()
                    platformActive = false
                    if platformRenderConnection then
                        platformRenderConnection:Disconnect()
                        platformRenderConnection = nil
                    end
                    platformStatusLabel.Text = "✅ Подъём завершён!"
                    task.wait(1.5)
                    if isAlive then
                        platformStatusLabel.Text = "✅ Персонаж жив"
                    end
                end)
            end
            
            platformStatusLabel.Text = "🔼 Платформа создана! Быстрый подъём..."
            platformStatusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
        end
    end
end

