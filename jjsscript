local dragging = false
local dragStartMousePos = Vector2.new()
local dragStartFramePos = Vector2.new()

titleBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStartMousePos = Vector2.new(input.Position.X, input.Position.Y)
        dragStartFramePos = Vector2.new(mainFrame.AbsolutePosition.X, mainFrame.AbsolutePosition.Y)
        titleBar.BackgroundColor3 = Color3.fromRGB(70, 70, 95)
    end
end)

titleBar.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local currentMousePos = Vector2.new(input.Position.X, input.Position.Y)
        local delta = currentMousePos - dragStartMousePos
        local newX = dragStartFramePos.X + delta.X
        local newY = dragStartFramePos.Y + delta.Y
        
        local screenSize = workspace.CurrentCamera.ViewportSize
        local frameSize = mainFrame.AbsoluteSize
        
        newX = math.clamp(newX, 0, screenSize.X - frameSize.X)
        newY = math.clamp(newY, 0, screenSize.Y - frameSize.Y)
        
        mainFrame.Position = UDim2.new(0, newX, 0, newY)
    end
end)

titleBar.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 and dragging then
        dragging = false
        titleBar.BackgroundColor3 = Color3.fromRGB(50, 50, 70)
    end
end)

