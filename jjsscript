-- Скорость Velocity
local function updateSpeedSlider(val)
    local p = (val - 0.1) / 4.9
    p = math.clamp(p, 0, 1)
    speedFill.Size = UDim2.new(p, 0, 1, 0)
    speedBtn.Position = UDim2.new(p, -10, 0.5, -10)
    speedValue.Text = "x" .. string.format("%.1f", val)
    velocityMultiplier = val
end

speedBtn.MouseButton1Down:Connect(function()
    local moving = true
    local con = UserInputService.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement and moving then
            local mp = UserInputService:GetMouseLocation()
            local sp = speedSlider.AbsolutePosition.X
            local sw = speedSlider.AbsoluteSize.X
            local p = (mp.X - sp) / sw
            p = math.clamp(p, 0, 1)
            local nv = 0.1 + p * 4.9
            updateSpeedSlider(nv)
            speedInput.Text = string.format("%.1f", nv)
        end
    end)
    local rel = UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            moving = false
            con:Disconnect()
            rel:Disconnect()
        end
    end)
end)

speedSlider.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        local mp = input.Position
        local sp = speedSlider.AbsolutePosition.X
        local sw = speedSlider.AbsoluteSize.X
        local p = (mp.X - sp) / sw
        p = math.clamp(p, 0, 1)
        local nv = 0.1 + p * 4.9
        updateSpeedSlider(nv)
        speedInput.Text = string.format("%.1f", nv)
    end
end)

