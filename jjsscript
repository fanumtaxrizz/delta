-- Форматирование чисел
local function formatNumber(num)
    if num >= 1000000 then
        return string.format("%.1fM", num / 1000000)
    elseif num >= 1000 then
        return string.format("%.1fK", num / 1000)
    else
        return tostring(num)
    end
end

-- ===== МЕТОДЫ ТЕЛЕПОРТАЦИИ =====

local function teleportViaVelocity(height)
    if not currentCharacter then return false end
    
    local hrp = currentCharacter:FindFirstChild("HumanoidRootPart")
    local humanoid = currentCharacter:FindFirstChild("Humanoid")
    
    if hrp and humanoid and humanoid.Health > 0 then
        local originalGravity = workspace.Gravity
        workspace.Gravity = 0
        
        -- Применяем множитель скорости
        local velocity = math.sqrt(2 * height * 50) * velocityMultiplier
        hrp.Velocity = Vector3.new(0, velocity, 0)
        hrp.AssemblyLinearVelocity = Vector3.new(0, velocity, 0)
        
        task.wait(0.05)
        workspace.Gravity = originalGravity
        return true
    end
    return false
end

local function teleportViaTween(height)
    if not currentCharacter then return false end
    
    local hrp = currentCharacter:FindFirstChild("HumanoidRootPart")
    if hrp then
        local targetPos = hrp.Position + Vector3.new(0, height, 0)
        local tween = TweenService:Create(hrp, TweenInfo.new(math.min(height / 500, 2), Enum.EasingStyle.Linear), {
            Position = targetPos
        })
        tween:Play()
        tween.Completed:Wait()
        return true
    end
    return false
end

local function teleportViaAttachments(height)
    if not currentCharacter then return false end
    
    local hrp = currentCharacter:FindFirstChild("HumanoidRootPart")
    if hrp then
        local attach = Instance.new("Attachment")
        attach.Parent = hrp
        
        local bv = Instance.new("BodyVelocity")
        bv.MaxForce = Vector3.new(0, math.huge, 0)
        bv.Velocity = Vector3.new(0, height * 2, 0)
        bv.Parent = attach
        
        task.wait(0.1)
        bv:Destroy()
        attach:Destroy()
        return true
    end
    return false
end

local function teleportViaNetwork(height)
    if not currentCharacter then return false end
    
    local hrp = currentCharacter:FindFirstChild("HumanoidRootPart")
    if hrp then
        hrp:SetNetworkOwner(player)
        task.wait()
        hrp.CFrame = hrp.CFrame + Vector3.new(0, height, 0)
        return true
    end
    return false
end

-- Главная функция телепортации
local function teleportUp()
    if not isAlive then
        statusLabel.Text = "❌ Вы мертвы! Возродитесь сначала"
        statusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
        
        teleportButton.BackgroundColor3 = Color3.fromRGB(100, 60, 60)
        task.wait(0.3)
        teleportButton.BackgroundColor3 = Color3.fromRGB(0, 120, 255)
        return
    end
    
    if not currentCharacter then
        statusLabel.Text = "⚠️ Персонаж не загружен..."
        return
    end
    
    local success = false
    
    if selectedMethod == "Velocity" then
        success = teleportViaVelocity(teleportHeight)
    elseif selectedMethod == "Tween" then
        success = teleportViaTween(teleportHeight)
    elseif selectedMethod == "Attachments" then
        success = teleportViaAttachments(teleportHeight)
    elseif selectedMethod == "Network" then
        success = teleportViaNetwork(teleportHeight)
    end
    
    if success then
        teleportCount = teleportCount + 1
        local speedText = (selectedMethod == "Velocity" and string.format(" (x%.1f)", velocityMultiplier) or "")
        counterLabel.Text = "Телепортов: " .. teleportCount .. " [" .. selectedMethod .. speedText .. "]"
        statusLabel.Text = "✅ Телепорт успешен!"
        statusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
        
        if currentCharacter and currentCharacter:FindFirstChild("HumanoidRootPart") then
            local hrp = currentCharacter.HumanoidRootPart
            local attachment = Instance.new("Attachment")
            attachment.Parent = hrp
            local smoke = Instance.new("Smoke")
            smoke.Parent = attachment
            game:GetService("Debris"):AddItem(smoke, 2)
            game:GetService("Debris"):AddItem(attachment, 2)
        end
        
        local clickTween = TweenService:Create(teleportButton, TweenInfo.new(0.1, Enum.EasingStyle.Quad), {
            BackgroundColor3 = Color3.fromRGB(0, 200, 100)
        })
        clickTween:Play()
        task.wait(0.1)
        local resetTween = TweenService:Create(teleportButton, TweenInfo.new(0.1, Enum.EasingStyle.Quad), {
            BackgroundColor3 = Color3.fromRGB(0, 120, 255)
        })
        resetTween:Play()
        
        task.wait(2)
        if isAlive then
            statusLabel.Text = "✅ Персонаж жив"
            statusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
        end
    else
        statusLabel.Text = "❌ Ошибка телепортации!"
        statusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
    end
end

