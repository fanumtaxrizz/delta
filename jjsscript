-- Функция форматирования чисел
local function formatNumber(num)
    if num >= 1000000 then
        return string.format("%.1fM", num / 1000000)
    elseif num >= 1000 then
        return string.format("%.1fK", num / 1000)
    else
        return tostring(num)
    end
end

-- ===== ФУНКЦИИ АИМБОТА =====
local function getClosestPlayer()
    local closestPlayer = nil
    local closestDistance = math.huge
    
    if not currentCharacter or not currentCharacter:FindFirstChild("HumanoidRootPart") then
        return nil
    end
    
    local myPosition = currentCharacter.HumanoidRootPart.Position
    
    for _, otherPlayer in ipairs(Players:GetPlayers()) do
        if otherPlayer ~= player then
            local otherChar = otherPlayer.Character
            if otherChar and otherChar:FindFirstChild("HumanoidRootPart") and otherChar:FindFirstChild("Humanoid") and otherChar.Humanoid.Health > 0 then
                local otherPosition = otherChar.HumanoidRootPart.Position
                local distance = (myPosition - otherPosition).Magnitude
                
                if distance < closestDistance and distance < 500 then
                    closestDistance = distance
                    closestPlayer = otherPlayer
                end
            end
        end
    end
    
    return closestPlayer
end

local function applySpray(targetPosition)
    if not sprayEnabled then
        return targetPosition
    end
    
    local offsetX = (math.random() - 0.5) * sprayAmount * 10
    local offsetY = (math.random() - 0.5) * sprayAmount * 8
    local offsetZ = (math.random() - 0.5) * sprayAmount * 10
    
    return targetPosition + Vector3.new(offsetX, offsetY, offsetZ)
end

local function startAimbot()
    if aimbotConnection then
        aimbotConnection:Disconnect()
        aimbotConnection = nil
    end
    
    aimbotConnection = RunService.RenderStepped:Connect(function()
        if aimbotEnabled and isAlive and currentCharacter then
            local targetPlayer = getClosestPlayer()
            
            if targetPlayer then
                local targetChar = targetPlayer.Character
                if targetChar and targetChar:FindFirstChild("HumanoidRootPart") then
                    local targetPos = targetChar.HumanoidRootPart.Position + Vector3.new(0, 1.5, 0)
                    local sprayedPos = applySpray(targetPos)
                    
                    local currentCFrame = camera.CFrame
                    local targetCFrame = CFrame.new(camera.CFrame.Position, sprayedPos)
                    
                    local newCFrame = currentCFrame:Lerp(targetCFrame, aimbotSmoothness)
                    camera.CFrame = newCFrame
                end
            end
        end
    end)
end

local function toggleAimbot()
    aimbotEnabled = not aimbotEnabled
    
    if aimbotEnabled then
